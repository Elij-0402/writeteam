# Vercel Environment Variable Mapping Example
# Set these values in Vercel Project Settings > Environment Variables.

# Shared across all environments
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Development only
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Preview only
# NEXT_PUBLIC_APP_URL=https://<project>-git-<branch>-<team>.vercel.app

# Production only
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# Server-side only secrets
AI_PROVIDER_BASE_URL=https://api.deepseek.com
AI_PROVIDER_MODEL=deepseek-chat
AI_PROVIDER_API_KEY=
SENTRY_DSN=
